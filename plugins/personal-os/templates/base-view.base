# {{view_name}}
# Auto-generated by Personal OS setup

filters:
  and:
    - file.hasTag("{{primary_tag}}")
    - file.inFolder("{{target_folder}}")

{{#if formulas}}
formulas:
{{#each formulas}}
  {{this.name}}: '{{this.expression}}'
{{/each}}
{{/if}}

{{#if properties}}
properties:
{{#each properties}}
  {{this.key}}:
    displayName: "{{this.display_name}}"
{{/each}}
{{/if}}

views:
  - type: table
    name: "{{view_name}}"
    {{#if group_by}}
    groupBy:
      property: {{group_by}}
      direction: ASC
    {{/if}}
    {{#if filters}}
    filters:
      {{filters}}
    {{/if}}
    order:
      - file.name
      {{#each display_columns}}
      - {{this}}
      {{/each}}
