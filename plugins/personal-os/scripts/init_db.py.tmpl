"""
Initialize {{domain_name}} database.
Run once: python3 init_{{domain_slug}}_db.py
"""
import sqlite3
from pathlib import Path

DB_PATH = Path(__file__).parent / "{{domain_slug}}.db"


def init():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()

    c.execute("""
        CREATE TABLE IF NOT EXISTS {{table_name}} (
            id         INTEGER PRIMARY KEY AUTOINCREMENT,
            date       TEXT NOT NULL DEFAULT (date('now')),
            {{#each columns}}
            {{this.name}}  {{this.type}}{{#if this.not_null}} NOT NULL{{/if}}{{#if this.default}} DEFAULT {{this.default}}{{/if}},
            {{/each}}
            created_at TEXT DEFAULT (datetime('now'))
        )
    """)

    {{#if seed_data}}
    # Seed data (optional)
    seed = [
        {{#each seed_data}}
        ({{this}}),
        {{/each}}
    ]
    c.executemany(
        "INSERT INTO {{table_name}} ({{seed_columns}}) VALUES ({{seed_placeholders}})",
        seed
    )
    {{/if}}

    conn.commit()
    conn.close()
    print(f"Initialized {{domain_slug}}.db at {DB_PATH}")


if __name__ == "__main__":
    init()
